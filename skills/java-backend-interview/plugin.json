{
  "id": "java-backend-interview",
  "name": "Java后端面试题",
  "description": "Java后端工程师面试题生成与知识体系整理",
  "version": "1.1.0",
  "commands": [
    {
      "name": "generate",
      "description": "生成面试题",
      "script": "python3 {baseDir}/scripts/interview_gen.py",
      "args": [
        {
          "name": "topic",
          "type": "string",
          "description": "面试题主题(java/jvm/concurrent/spring/database/cache/distributed/design)",
          "required": false
        },
        {
          "name": "level",
          "type": "string",
          "description": "难度等级(junior/middle/senior/architect)",
          "default": "senior"
        },
        {
          "name": "count",
          "type": "number",
          "description": "生成题目数量",
          "default": 3
        },
        {
          "name": "random",
          "type": "boolean",
          "description": "随机生成面试题",
          "default": false
        },
        {
          "name": "knowledge",
          "type": "boolean",
          "description": "显示知识体系",
          "default": false
        },
        {
          "name": "output",
          "type": "string",
          "description": "输出文档路径",
          "required": false
        }
      ]
    },
    {
      "name": "daily",
      "description": "每日更新面试题",
      "script": "python3 {baseDir}/scripts/interview_gen.py --daily",
      "args": []
    },
    {
      "name": "update",
      "description": "更新知识库",
      "script": "python3 {baseDir}/scripts/interview_gen.py --update",
      "args": [
        {
          "name": "topic",
          "type": "string",
          "description": "要更新的主题",
          "required": true
        },
        {
          "name": "count",
          "type": "number",
          "description": "搜索题目数量",
          "default": 5
        },
        {
          "name": "output",
          "type": "string",
          "description": "输出文档路径",
          "required": false
        }
      ]
    }
  ]
}
